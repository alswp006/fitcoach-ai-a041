# 이 파일은 앱이 사용하는 모든 환경변수의 단일 정의처다.
# 이후 패킷은 이 파일을 수정하지 말고 import.meta.env.VITE_* 로 참조만 할 것.
# 실제 값은 절대 커밋하지 말 것 — 로컬 개발은 .env.local(gitignore됨)에 채워 사용.

# Railway AI API 베이스 URL
VITE_API_BASE_URL=https://your-api-url.railway.app

# 토스 배너 광고 그룹 ID — 앱인토스 콘솔에서 발급/변경(재빌드 불필요, 런타임 주입)
VITE_TOSS_AD_GROUP_ID=your_ad_group_id

# 토스 보상형/전면 광고 슬롯 ID — 앱인토스 콘솔에서 발급/변경(재빌드 불필요, 런타임 주입)
VITE_TOSS_AD_SLOT_ID=your_ad_slot_id

# 토스 인앱 결제(IAP) 상품 SKU — 프리미엄 월 12,900원 (앱인토스 콘솔에서 발급/변경, 재빌드 불필요)
VITE_TOSS_IAP_SKU=your_iap_sku

# 토스 프로모션 코드 — 앱인토스 콘솔에서 발급/변경(재빌드 불필요, 런타임 주입)
VITE_TOSS_PROMOTION_CODE=your_promotion_code
